# ── Required ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Infrastructure ─────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=rag_proto


# ── Embedding ──────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=100
EMBEDDING_DIM=1536

# ── HNSW Index ─────────────────────────────────────
HNSW_M=8
HNSW_EF_CONSTRUCTION=100
HNSW_EF_SEARCH=100

# ── Chunking ───────────────────────────────────────
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_MIN_TOKENS=20

# ── Docling ────────────────────────────────────────
DOCLING_OCR_BACKEND=easyocr
DOCLING_TABLE_MODE=accurate
DOCLING_CACHE_DIR=./.docling_cache

# ── Verification ───────────────────────────────────
L2_VERIFY_SAMPLE_CHARS=800
L2_VERIFY_CHUNK_SAMPLE=3
GROUND_TRUTH_DIR=./demo_docs

# ── Limits ─────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_PAGES=200
LOG_LEVEL=INFO
